# 99-mamaohub.rules - Regole per persistent names porte Waveshare 4CH
# Basato su FT4232H (idVendor=0403, idProduct=6011)

# Fase 1: Identifica il dispositivo e memorizza il numero di interfaccia
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", ENV{.LOCAL_ifNum}="$attr{bInterfaceNumber}"

# Fase 2: Crea i symlink mnemonici basati sull'interfaccia
# Porta 1: Stazione Vento
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", ENV{.LOCAL_ifNum}=="00", SYMLINK+="ttyUSB_VENTO", GROUP="dialout", MODE="0660"

# Porta 2: Bussola
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", ENV{.LOCAL_ifNum}=="01", SYMLINK+="ttyUSB_BUSSOLA", GROUP="dialout", MODE="0660"

# Porta 3: Navigatore (Rientro Segnale Completo)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", ENV{.LOCAL_ifNum}=="02", SYMLINK+="ttyUSB_NAV_IN", GROUP="dialout", MODE="0660"

# Porta 4: Libera
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", ENV{.LOCAL_ifNum}=="03", SYMLINK+="ttyUSB_FREE", GROUP="dialout", MODE="0660"
